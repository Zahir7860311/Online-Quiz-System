<!DOCTYPE html>
<html>
<head>
<title>Edit Question</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
body { font-family: Arial; background: #f4f4f4; }
.section { width: 50%; margin: 60px auto; background: white; padding: 40px; border-radius: 10px; box-shadow: 0 0 10px rgba(0,0,0,0.08); }
h2 { color: #7b2cbf; border-bottom: 2px solid #7b2cbf; padding-bottom: 8px; margin-bottom: 20px; }
</style>
</head>
<body>

<div class="section">
    <h2>✏️ Edit Question</h2>
    <form action="/admin/edit-question/<%= question._id %>" method="POST">
        <div class="mb-3">
            <label>Topic</label>
            <select name="topic" class="form-control" required>
                <option value="html" <%= question.topic === "html" ? "selected" : "" %>>HTML</option>
                <option value="css" <%= question.topic === "css" ? "selected" : "" %>>CSS</option>
                <option value="java" <%= question.topic === "java" ? "selected" : "" %>>Java</option>
                <option value="python" <%= question.topic === "python" ? "selected" : "" %>>Python</option>
                <option value="gk" <%= question.topic === "gk" ? "selected" : "" %>>General Knowledge</option>
            </select>
        </div>
        <div class="mb-3">
            <label>Question</label>
            <input type="text" name="question" class="form-control" value="<%= question.question %>" required>
        </div>
        <div class="mb-3">
            <label>Option 1</label>
            <input type="text" name="option1" class="form-control" value="<%= question.options[0] %>" required>
        </div>
        <div class="mb-3">
            <label>Option 2</label>
            <input type="text" name="option2" class="form-control" value="<%= question.options[1] %>" required>
        </div>
        <div class="mb-3">
            <label>Option 3</label>
            <input type="text" name="option3" class="form-control" value="<%= question.options[2] %>" required>
        </div>
        <div class="mb-3">
            <label>Correct Answer</label>
            <input type="text" name="answer" class="form-control" value="<%= question.answer %>" required>
        </div>
        <button type="submit" class="btn btn-success">Save Changes</button>
        <a href="/admin" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>

</body>
</html>
