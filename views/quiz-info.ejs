<!DOCTYPE html>
<html>

<head>
    <title>Quiz Info</title>
</head>

<body style="background:#f3f4f6; text-align:center; margin-top:120px;">

    <h2 style="color:#7b2cbf;">QUIZ INFORMATION</h2>

    <p><strong>Selected Quiz Topic:</strong>
        <%= topic.toUpperCase() %>
    </p>
    <p><strong>Total Questions:</strong>
        <%= total %>
    </p>
    <p><strong>Total Score:</strong>
        <%= total * 5 %>
    </p>
    <p><strong>Total Time:</strong> 10 Minutes</p>

    <a href="/quiz/<%= topic %>">
        <button style="padding:10px 30px;
                   background:linear-gradient(45deg,#7b2cbf,#c77dff);
                   border:none;
                   color:white;">
            Start
        </button>
    </a>

</body>

</html>