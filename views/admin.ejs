<!DOCTYPE html>
<html>
<head>
<title>Admin Panel</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
body { font-family: Arial; background: #f4f4f4; }
th { background: purple; color: white; }
.section { width: 80%; margin: 30px auto; background: white; padding: 30px; border-radius: 10px; box-shadow: 0 0 10px rgba(0,0,0,0.08); }
h1 { text-align: center; padding: 30px 0 10px; color: #7b2cbf; }
h2 { color: #444; border-bottom: 2px solid #7b2cbf; padding-bottom: 8px; margin-bottom: 20px; }
</style>
</head>
<body>

<h1>🔧 Admin Dashboard</h1>

<!-- ===== USERS ===== -->
<div class="section">
    <h2>👤 Registered Users</h2>
    <table class="table table-bordered">
        <tr><th>Username</th><th>Email</th><th>Role</th></tr>
        <% users.forEach(function(user){ %>
        <tr>
            <td><%= user.username %></td>
            <td><%= user.email %></td>
            <td><%= user.role || "user" %></td>
        </tr>
        <% }) %>
    </table>
</div>

<!-- ===== SCORES ===== -->
<div class="section">
    <h2>🏆 Quiz Scores</h2>
    <table class="table table-bordered">
        <tr><th>Username</th><th>Topic</th><th>Score</th></tr>
        <% scores.forEach(function(score){ %>
        <tr>
            <td><%= score.username %></td>
            <td><%= score.topic %></td>
            <td><%= score.score %></td>
        </tr>
        <% }) %>
    </table>
</div>

<!-- ===== ADD QUESTION ===== -->
<div class="section">
    <h2>➕ Add New Question</h2>
    <form action="/admin/add-question" method="POST">
        <div class="mb-3">
            <label>Topic</label>
            <select name="topic" class="form-control" required>
                <option value="html">HTML</option>
                <option value="css">CSS</option>
                <option value="java">Java</option>
                <option value="python">Python</option>
                <option value="gk">General Knowledge</option>
            </select>
        </div>
        <div class="mb-3">
            <label>Question</label>
            <input type="text" name="question" class="form-control" required>
        </div>
        <div class="mb-3">
            <label>Option 1</label>
            <input type="text" name="option1" class="form-control" required>
        </div>
        <div class="mb-3">
            <label>Option 2</label>
            <input type="text" name="option2" class="form-control" required>
        </div>
        <div class="mb-3">
            <label>Option 3</label>
            <input type="text" name="option3" class="form-control" required>
        </div>
        <div class="mb-3">
            <label>Correct Answer (must match one of the options exactly)</label>
            <input type="text" name="answer" class="form-control" required>
        </div>
        <button type="submit" class="btn btn-success">Add Question</button>
    </form>
</div>

<!-- ===== MANAGE QUESTIONS ===== -->
<div class="section">
    <h2>📝 Manage Questions</h2>
    <table class="table table-bordered">
        <tr><th>Topic</th><th>Question</th><th>Options</th><th>Answer</th><th>Actions</th></tr>
        <% questions.forEach(function(q){ %>
        <tr>
            <td><%= q.topic %></td>
            <td><%= q.question %></td>
            <td><%= q.options.join(", ") %></td>
            <td><%= q.answer %></td>
            <td>
                <a href="/admin/edit-question/<%= q._id %>" class="btn btn-sm btn-warning">Edit</a>
                <form action="/admin/delete-question/<%= q._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Delete this question?')">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
        <% }) %>
    </table>
</div>

<div style="text-align:center; padding: 20px;">
    <a href="/" class="btn btn-secondary">Go Home</a>
</div>

</body>
</html>
