<!DOCTYPE html>
<html>

<head>
    <title>Group 5 Quiz</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f3f4f6;
            font-family: 'Segoe UI', sans-serif;
        }

        .main-card {
            width: 900px;
            margin: 60px auto;
            background: white;
            padding: 50px;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.08);
            text-align: center;
        }

        .logo-box {
            border: 2px dashed black;
            padding: 5px 12px;
            display: inline-block;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .logo-text {
            font-family: cursive;
            font-size: 22px;
            margin-left: 10px;
        }

        .topic-btn {
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 12px 25px;
            margin: 10px;
            background: #fff;
            cursor: pointer;
            transition: 0.3s;
        }

        .topic-btn:hover {
            border-color: #7b2cbf;
            box-shadow: 0 5px 10px rgba(0, 0, 0, 0.05);
        }

        .topic-btn.active {
            border-color: #7b2cbf;
            box-shadow: 0 5px 10px rgba(0, 0, 0, 0.1);
        }

        .continue-btn {
            margin-top: 40px;
            padding: 12px 40px;
            border-radius: 25px;
            border: none;
            font-size: 18px;
            color: white;
            background: linear-gradient(45deg, #7b2cbf, #c77dff);
        }

        .continue-btn:hover {
            opacity: 0.9;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .admin-btn {
            padding: 8px 20px;
            border-radius: 20px;
            border: none;
            background: linear-gradient(45deg, #c0392b, #e74c3c);
            color: white;
            font-size: 14px;
            text-decoration: none;
        }

        .admin-btn:hover {
            opacity: 0.85;
            color: white;
        }

        .logout-btn {
            padding: 8px 20px;
            border-radius: 20px;
            border: none;
            background: #eee;
            color: #333;
            font-size: 14px;
            text-decoration: none;
        }

        .logout-btn:hover {
            background: #ddd;
            color: #333;
        }
    </style>
</head>

<body>

    <div class="main-card">

        <!-- Top Bar -->
        <div class="top-bar">
            <span style="font-size:14px; color:#888;">👤 Welcome, <strong><%= user.username %></strong></span>
            <div>
                <% if (user.role === "admin") { %>
                    <a href="/admin" class="admin-btn me-2">🔧 Admin Panel</a>
                <% } %>
                <a href="/leaderboard" class="logout-btn me-2">🏆 Leaderboard</a>
                <a href="/logout" class="logout-btn">Logout</a>
            </div>
        </div>

        <!-- Logo Section -->
        <div>
            <span class="logo-box">XQ</span>
            <span class="logo-text">Group 5 Quiz</span>
        </div>

        <h3 class="mt-4">
            WELCOME TO <span style="color:#7b2cbf;">QUIZ APPLICATION</span>
        </h3>

        <p>Select topic below to start your Quiz.</p>

        <!-- Topics -->
        <div class="mt-4">
            <button class="topic-btn" onclick="selectTopic(this,'html')">HTML</button>
            <button class="topic-btn" onclick="selectTopic(this,'css')">CSS</button>
            <button class="topic-btn" onclick="selectTopic(this,'java')">Java</button>
            <button class="topic-btn" onclick="selectTopic(this,'python')">Python</button>
            <button class="topic-btn" onclick="selectTopic(this,'gk')">General Knowledge</button>
        </div>

        <button class="continue-btn" onclick="goToQuiz()">Continue</button>

    </div>

    <script>
        let selected = "";

        function selectTopic(element, topic) {
            selected = topic;
            document.querySelectorAll(".topic-btn").forEach(btn => {
                btn.classList.remove("active");
            });
            element.classList.add("active");
        }

        function goToQuiz() {
            if (selected === "") {
                alert("Please select a topic first!");
            } else {
                window.location.href = "/quiz-info/" + selected;
            }
        }
    </script>

</body>

</html>
