<!DOCTYPE html>
<html>

<head>
    <title>Quiz</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(to right, #7b2cbf, #c77dff);
            font-family: 'Segoe UI', sans-serif;
        }

        .quiz-card {
            width: 850px;
            margin: 60px auto;
            background: white;
            padding: 40px;
            border-radius: 12px;
        }

        .question-number {
            font-size: 28px;
            font-weight: bold;
            color: #7b2cbf;
        }

        .timer {
            float: right;
            font-weight: bold;
            font-size: 18px;
        }

        .option-box {
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 12px 20px;
            margin-bottom: 15px;
            cursor: pointer;
            transition: 0.3s;
            display: block;
        }

        .option-box:hover {
            border-color: #7b2cbf;
            background: #f8f4ff;
        }

        .option-box input {
            display: none;
        }

        .option-box input:checked+span {
            color: #7b2cbf;
            font-weight: bold;
        }

        .option-box input:checked+span::before {
            content: "✔ ";
            color: #7b2cbf;
            font-weight: bold;
        }

        .submit-btn {
            float: right;
            padding: 8px 25px;
            border-radius: 20px;
            border: none;
            background: linear-gradient(45deg, #7b2cbf, #c77dff);
            color: white;
        }
    </style>
</head>

<body>

    <div class="quiz-card">

        <div>
            <span class="question-number">
                01 / <%= questions.length %>
            </span>

            <span class="timer">
                ⏱ <span id="time">10:00</span>
            </span>
        </div>

        <hr>

        <form action="/result" method="POST">

            <!-- ✅ VERY IMPORTANT: Send topic -->
            <input type="hidden" name="topic" value="<%= topic %>">

            <% questions.forEach(function(q){ %>

                <h5 class="mb-4">
                    <%= q.question %>
                </h5>

                <% q.options.forEach(function(option){ %>

                    <label class="option-box">

                        <!-- ✅ FIXED VALUE -->
                        <input type="radio" name="<%= q.name %>" value="<%= option %>" required>

                        <span>
                            <%= option %>
                        </span>

                    </label>

                    <% }); %>

                        <% }); %>

                            <button type="submit" class="submit-btn mt-3">
                                Submit
                            </button>

        </form>

    </div>

    <script>
        let totalSeconds = 600;
        const timerElement = document.getElementById("time");

        const countdown = setInterval(() => {

            let minutes = Math.floor(totalSeconds / 60);
            let seconds = totalSeconds % 60;

            seconds = seconds < 10 ? "0" + seconds : seconds;
            timerElement.innerText = minutes + ":" + seconds;

            totalSeconds--;

            if (totalSeconds < 0) {
                clearInterval(countdown);
                alert("Time's up!");
                document.querySelector("form").submit();
            }

        }, 1000);
    </script>

</body>

</html>